{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "__backend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ts-node", "./src/index.ts"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "preLaunchTask": "backend: Postgres (docker up)",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "__frontend_chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "frontend: Vite dev",
      "sourceMaps": true,
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "DDD Forum (full stack)",
      "configurations": ["__backend", "__frontend_chrome"],
      "stopAll": true
    }
  ]
}
