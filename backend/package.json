{
  "name": "@dddforum/backend",
  "version": "1.0.0",
  "description": "A basic typescript app starter for 2023.",
  "main": "index.js",
  "scripts": {
    "build": "rimraf ./build && tsc",
    "start:dev": "npm run db:setup && npm run db:seed && npx nodemon",
    "start": "npm run build && node build/index.js",
    "lint": "eslint . --ext .ts",
    "prettier-format": "run-script-os",
    "prettier-format:win32": "prettier --config .prettierrc \"./src/**/*.ts\" --write",
    "prettier-format:darwin:linux": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "prettier-format:default": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "prettier-watch": "run-script-os",
    "prettier-watch:win32": "onchange \"src/**/*.ts\" -- prettier --write {{changed}}",
    "prettier-watch:darwin:linux": "onchange 'src/**/*.ts' -- prettier --write {{changed}}",
    "prettier-watch:default": "onchange 'src/**/*.ts' -- prettier --write {{changed}}",
    "test": "jest",
    "test:dev": "jest --watchAll",
    "test:e2e": "jest -c jest.config.e2e.ts",
    "test:infra": "jest --config jest.config.infra.ts --passWithNoTests",
    "test:unit": "jest --config jest.config.unit.ts --passWithNoTests",
    "test:e2e:dev": "jest --config jest.config.e2e.ts --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "start:db:dev": "docker-compose up -d",
    "db:up": "docker start development-postgres 2>/dev/null || docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate deploy",
    "db:setup": "(docker start development-postgres 2>/dev/null || docker compose up -d --wait) && npm run db:migrate",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run test && npm run prettier-format && npm run lint"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "onchange": "^7.1.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "run-script-os": "^1.1.6",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jest-cucumber": "^4.5.0",
    "pg": "^8.20.0",
    "prisma": "7.7.0"
  }
}
